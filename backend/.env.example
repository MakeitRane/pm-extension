# Kalshi API Key (optional - can also be passed from frontend)
KALSHI_API_KEY=your-api-key-here

# Server configuration
PORT=5001
DEBUG=True

RSA_KEY="-----BEGIN PRIVATE KEY-----\nyour-private-key-content-here\n-----END PRIVATE KEY-----"

# Gemini API Keys (both required for search)
# Stage 1: gemini-3-flash-preview (high context, filters all markets to top 50)
# Rate limits: 4 RPM, 250k TPM, 18 RPD
GEMINI_API_KEY_1=your-gemini-api-key-1-here

# Stage 2: gemma-3-27b-it (causal analysis on top 50 to find top 5)
# Rate limits: 28 RPM, 14k TPM, 14k RPD
GEMINI_API_KEY_2=your-gemini-api-key-2-here
