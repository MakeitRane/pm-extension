# =============================================================================
# Kalshi Markets Finder - Backend Configuration
# =============================================================================

# --- Required ---

# Gemini API keys (both required for two-stage market analysis)
GEMINI_API_KEY_1=        # Stage 1: gemini-3-flash-preview (relevance filter)
GEMINI_API_KEY_2=        # Stage 2: gemma-3-27b-it (causal analysis)

# --- Optional ---

# Kalshi API Key ID (for WebSocket real-time prices)
KALSHI_API_KEY=

# RSA private key PEM (for WebSocket authentication)
# Use \n for newlines in the PEM content
RSA_KEY=

# --- Server ---

PORT=5001
DEBUG=False

# Comma-separated additional CORS origins (optional)
# ALLOWED_ORIGINS=https://your-app.com

# Logging level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO
